<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Conteúdo principal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1A237E"
            android:elevation="4dp"
            app:title="Chamados"
            app:titleTextColor="#FFFFFF"
            app:navigationIconTint="#FFFFFF"/>

        <!-- Conteúdo central -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="#F0F2F5"
            android:padding="24dp"
            android:gravity="center">

            <!-- Cabeçalho -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#FFFFFF"
                android:padding="32dp"
                android:elevation="2dp"
                android:layout_marginBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📋"
                    android:textSize="48sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chamados"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#1A237E"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sistema de Registro e Atendimento"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <!-- Botões -->
            <Button
                android:id="@+id/btnCadastrar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="＋  Novo Chamado"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#1A237E"
                android:layout_marginBottom="12dp"
                />

            <Button
                android:id="@+id/btnLista"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="☰  Ver Todos os Chamados"
                android:textSize="15sp"
                android:backgroundTint="#283593"
                android:layout_marginBottom="12dp"
                />

            <Button
                android:id="@+id/btnFiltro"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🔍  Buscar / Filtrar"
                android:textSize="15sp"
                android:backgroundTint="#3949AB"
                />

        </LinearLayout>
    </LinearLayout>

    <!-- Menu lateral -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FFFFFF"
        app:itemTextColor="#1A237E"
        app:itemIconTint="#1A237E"
        app:menu="@menu/nav_menu"/>

</androidx.drawerlayout.widget.DrawerLayout>