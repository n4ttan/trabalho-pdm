<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📋 Chamados"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#1A237E"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sistema de Registro e Atendimento"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnCadastrar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Novo Chamado"
        android:textSize="16sp"
        android:backgroundTint="#1A237E"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnLista"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Ver Todos os Chamados"
        android:textSize="16sp"
        android:backgroundTint="#283593"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnFiltro"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Buscar / Filtrar"
        android:textSize="16sp"
        android:backgroundTint="#3949AB"/>

</LinearLayout>